{
  "name": "mool-clone",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate deploy",
    "db:migrate:prod": "dotenv -e .env.production.local -- prisma migrate deploy",
    "db:baseline-local": "dotenv -e .env.local -- prisma db push && dotenv -e .env.local -- prisma migrate resolve --applied 20260430160000_add_dashboard_models && dotenv -e .env.local -- prisma migrate deploy",
    "db:baseline-prod": "dotenv -e .env.production.local -- prisma db push && dotenv -e .env.production.local -- prisma migrate resolve --applied 20260430160000_add_dashboard_models && dotenv -e .env.production.local -- prisma migrate deploy",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "admin:hash-password": "node scripts/hash-admin-password.js"
  },
