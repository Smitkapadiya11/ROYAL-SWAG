# Copy to .env.local for development. Set the same keys in Vercel → Project → Settings → Environment Variables.

# --- Public (browser / edge-safe) ---
NEXT_PUBLIC_PHONE_NUMBER=
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_EMAIL=
NEXT_PUBLIC_ADDRESS_LINE1=
NEXT_PUBLIC_ADDRESS_LINE2=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_YOUTUBE_URL=
NEXT_PUBLIC_FACEBOOK_URL=

# Product UI (optional overrides; code has defaults)
NEXT_PUBLIC_STOCK_COUNT=
NEXT_PUBLIC_PRICE_20DAY=
NEXT_PUBLIC_PRICE_40DAY=
NEXT_PUBLIC_PRICE_60DAY=
NEXT_PUBLIC_MRP_20DAY=
NEXT_PUBLIC_MRP_40DAY=
NEXT_PUBLIC_MRP_60DAY=

# Supabase (client + save-lead API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-only (never NEXT_PUBLIC_) ---
# Razorpay: key is returned from /api/create-order for checkout; keep secret on server.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Supabase service role (save-lead / server writes)
SUPABASE_SERVICE_ROLE_KEY=

# PostgreSQL (Prisma: orders, lung tests, admin sessions)
# Copy into .env.local for Next.js + local Prisma (npm run db:*).
#
# For migrations against PRODUCTION (Vercel) DB only: create .env.production.local in repo root with ONE line:
#   DATABASE_URL="postgresql://..."   (paste exact URI from Vercel)
# Then: npm run db:migrate:prod
# If you see P3005 on migrate deploy, run once: npm run db:baseline-prod  (uses .env.production.local)
# Supabase direct (dev): postgresql://postgres:PASSWORD@db.REF.supabase.co:5432/postgres?sslmode=require
# Vercel/serverless: prefer Session pooler URI from Supabase Connect tab; often append &connection_limit=1 (see Prisma + Supabase docs).
# Neon: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Admin dashboard (/admin/login → cookie session in DB)
# ADMIN_PASSWORD_HASH = SHA-256 hex of your password (npm run admin:hash-password -- "yourpassword")
# Optional: if hash/env typos on Vercel break login, set ADMIN_PASSWORD (plain) — prefer hash only long-term.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
# Comma-separated allowed passwords (optional alternative to hash).
ADMIN_PASSWORD=
# Optional — not used by login today; keep for future features
ADMIN_SECRET_KEY=

# Google Sheets (service account — append rows to spreadsheet; share sheet with client_email)
GOOGLE_PROJECT_ID=
GOOGLE_PRIVATE_KEY_ID=
GOOGLE_PRIVATE_KEY=
GOOGLE_CLIENT_EMAIL=
GOOGLE_CLIENT_ID=
GOOGLE_SPREADSHEET_ID=
